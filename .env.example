# RelationalSEO MCP server configuration.
# Copy this file to `.env` (which is git-ignored) or set these in your MCP
# client config. NEVER commit your real token.

# Required: your personal RelationalSEO API token (Bearer token).
# Find it in the RelationalSEO dashboard under the API page.
RELATIONALSEO_API_KEY=your_token_here

# Optional: override the API base URL (defaults to the production API).
# RELATIONALSEO_BASE_URL=https://login.relationalseo.com/api/v1

# Optional: per-request timeout in milliseconds (default: 120000 = 2 min).
# Analyses are LLM-backed and can take a while; the combined endpoint runs
# several tools in parallel and uses a longer internal timeout.
# RELATIONALSEO_TIMEOUT_MS=120000
